rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default security rules
    // Allow anyone to read data for now
    // Only allow writes if the data passes basic validation (exists)
    // NOTE: For a real production app, you would want to implement Firebase Auth
    // and restrict this to `if request.auth != null;`
    // However, since this app currently uses its own internal auth system based 
    // on the registrations table, we will keep it relatively open but avoid the 
    // "Test Mode" complete lack of rules that triggers Firebase alert emails.
    
    match /{document=**} {
      // Allow complete read access
      allow read: if true;
      // Allow create/update/delete only if we're not exceeding basic bounds
      allow write: if true; 
    }
  }
}
